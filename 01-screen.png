<style>
  * { box-sizing: border-box; }
  html, body { margin: 0; padding: 0; }
  ::selection { background: #E8B881; color: #241F40; }
  @page { size: A4; margin: 0; }
  @media print {
    body { background: #fff !important; }
    .bb-gutter { background: #fff !important; padding: 0 !important; gap: 0 !important; }
    .bb-page { box-shadow: none !important; break-after: page; break-inside: avoid; }
  }
</style>
</helmet>

<div class="bb-gutter" style="background:#D9D2C6;padding:40px 24px;display:flex;flex-direction:column;align-items:center;gap:30px;min-height:100vh;font-family:'Newsreader',serif;">

  <!-- ============ 01 · PORTADA ============ -->
  <div class="bb-page" data-screen-label="Portada" style="position:relative;width:794px;height:1123px;flex:none;background:#2B2752;color:#F4EFE7;box-shadow:0 24px 60px -28px rgba(20,16,40,0.6);overflow:hidden;">
    <div style="position:absolute;inset:0;background:radial-gradient(120% 80% at 50% 8%, rgba(232,184,129,0.10), transparent 60%);"></div>
    <div style="position:absolute;top:54px;left:60px;right:60px;display:flex;justify-content:space-between;align-items:center;">
      <div style="display:flex;align-items:center;gap:10px;">
        <svg width="26" height="26" viewBox="0 0 64 64"><g fill="#F4EFE7"><ellipse cx="12" cy="29" rx="8.5" ry="13"/><ellipse cx="52" cy="29" rx="8.5" ry="13"/><path d="M16 26 C16 15 25 11 32 11 C39 11 48 15 48 26 C48 35 44 41 40 44 C40.5 49 41 53 38 57.5 C36 60.5 32 60.5 31 57.5 C30.2 55 31.5 51.5 33 49.5 C27 47 18 40 16 26 Z"/></g></svg>
        <span style="font:600 18px 'Newsreader',serif;letter-spacing:-0.01em;">Elephant</span>
      </div>
      <span style="font:500 12px 'Hanken Grotesk';letter-spacing:0.18em;text-transform:uppercase;color:rgba(244,239,231,0.5);">v1.0 · 2025</span>
    </div>

    <div style="position:absolute;top:50%;left:60px;right:60px;transform:translateY(-50%);">
      <svg width="92" height="92" viewBox="0 0 64 64" style="margin-bottom:38px;"><g fill="#E8B881"><ellipse cx="12" cy="29" rx="8.5" ry="13"/><ellipse cx="52" cy="29" rx="8.5" ry="13"/><path d="M16 26 C16 15 25 11 32 11 C39 11 48 15 48 26 C48 35 44 41 40 44 C40.5 49 41 53 38 57.5 C36 60.5 32 60.5 31 57.5 C30.2 55 31.5 51.5 33 49.5 C27 47 18 40 16 26 Z"/></g></svg>
      <div style="font:500 13px 'Hanken Grotesk';letter-spacing:0.28em;text-transform:uppercase;color:rgba(232,184,129,0.9);">Manual de marca</div>
      <h1 style="font:300 96px/0.98 'Newsreader',serif;letter-spacing:-0.03em;margin:18px 0 0;">Elephant</h1>
      <p style="font:400 italic 27px/1.4 'Newsreader',serif;color:rgba(244,239,231,0.72);margin:26px 0 0;max-width:520px;">Un elefante nunca olvida — y nuestra marca tampoco deja que tú lo hagas.</p>
    </div>

    <div style="position:absolute;bottom:54px;left:60px;right:60px;display:flex;justify-content:space-between;align-items:flex-end;border-top:1px solid rgba(244,239,231,0.18);padding-top:20px;">
      <span style="font:400 15px 'Newsreader',serif;color:rgba(244,239,231,0.6);">Identidad visual y verbal</span>
      <span style="font:500 12px 'Hanken Grotesk';letter-spacing:0.1em;color:rgba(244,239,231,0.45);">Documento interno · diseño + desarrollo</span>
    </div>
  </div>

  <!-- ============ 02 · ÍNDICE ============ -->
  <div class="bb-page" data-screen-label="Índice" style="position:relative;width:794px;height:1123px;flex:none;background:#F4EFE7;color:#221C16;box-shadow:0 24px 60px -28px rgba(20,16,40,0.35);padding:72px 64px 60px;">
    <div style="font:500 12px 'Hanken Grotesk';letter-spacing:0.22em;text-transform:uppercase;color:#A99F90;">Contenido</div>
    <h2 style="font:300 52px/1.04 'Newsreader',serif;letter-spacing:-0.02em;margin:14px 0 48px;">Qué hay dentro</h2>

    <div style="display:flex;flex-direction:column;">
      <div style="display:flex;align-items:baseline;gap:18px;padding:17px 0;border-top:1px solid #E3DBCC;"><span style="font:500 14px 'Hanken Grotesk';color:#B0917E;width:34px;flex:none;">01</span><span style="font:400 23px 'Newsreader',serif;flex:1;">La marca · esencia y promesa</span><span style="font:500 13px 'Hanken Grotesk';color:#A99F90;">03</span></div>
      <div style="display:flex;align-items:baseline;gap:18px;padding:17px 0;border-top:1px solid #E3DBCC;"><span style="font:500 14px 'Hanken Grotesk';color:#B0917E;width:34px;flex:none;">02</span><span style="font:400 23px 'Newsreader',serif;flex:1;">Personalidad y tono de voz</span><span style="font:500 13px 'Hanken Grotesk';color:#A99F90;">04</span></div>
      <div style="display:flex;align-items:baseline;gap:18px;padding:17px 0;border-top:1px solid #E3DBCC;"><span style="font:500 14px 'Hanken Grotesk';color:#B0917E;width:34px;flex:none;">03</span><span style="font:400 23px 'Newsreader',serif;flex:1;">Logotipo · construcción y respeto</span><span style="font:500 13px 'Hanken Grotesk';color:#A99F90;">05</span></div>
      <div style="display:flex;align-items:baseline;gap:18px;padding:17px 0;border-top:1px solid #E3DBCC;"><span style="font:500 14px 'Hanken Grotesk';color:#B0917E;width:34px;flex:none;">04</span><span style="font:400 23px 'Newsreader',serif;flex:1;">Logotipo · usos incorrectos</span><span style="font:500 13px 'Hanken Grotesk';color:#A99F90;">06</span></div>
      <div style="display:flex;align-items:baseline;gap:18px;padding:17px 0;border-top:1px solid #E3DBCC;"><span style="font:500 14px 'Hanken Grotesk';color:#B0917E;width:34px;flex:none;">05</span><span style="font:400 23px 'Newsreader',serif;flex:1;">Color</span><span style="font:500 13px 'Hanken Grotesk';color:#A99F90;">07</span></div>
      <div style="display:flex;align-items:baseline;gap:18px;padding:17px 0;border-top:1px solid #E3DBCC;"><span style="font:500 14px 'Hanken Grotesk';color:#B0917E;width:34px;flex:none;">06</span><span style="font:400 23px 'Newsreader',serif;flex:1;">Tipografía</span><span style="font:500 13px 'Hanken Grotesk';color:#A99F90;">08</span></div>
      <div style="display:flex;align-items:baseline;gap:18px;padding:17px 0;border-top:1px solid #E3DBCC;"><span style="font:500 14px 'Hanken Grotesk';color:#B0917E;width:34px;flex:none;">07</span><span style="font:400 23px 'Newsreader',serif;flex:1;">Lenguaje de ilustración · las escenas</span><span style="font:500 13px 'Hanken Grotesk';color:#A99F90;">09</span></div>
      <div style="display:flex;align-items:baseline;gap:18px;padding:17px 0;border-top:1px solid #E3DBCC;"><span style="font:500 14px 'Hanken Grotesk';color:#B0917E;width:34px;flex:none;">08</span><span style="font:400 23px 'Newsreader',serif;flex:1;">Componente héroe · la tarjeta de escena</span><span style="font:500 13px 'Hanken Grotesk';color:#A99F90;">10</span></div>
      <div style="display:flex;align-items:baseline;gap:18px;padding:17px 0;border-top:1px solid #E3DBCC;"><span style="font:500 14px 'Hanken Grotesk';color:#B0917E;width:34px;flex:none;">09</span><span style="font:400 23px 'Newsreader',serif;flex:1;">Componentes de interfaz</span><span style="font:500 13px 'Hanken Grotesk';color:#A99F90;">11</span></div>
      <div style="display:flex;align-items:baseline;gap:18px;padding:17px 0;border-top:1px solid #E3DBCC;border-bottom:1px solid #E3DBCC;"><span style="font:500 14px 'Hanken Grotesk';color:#B0917E;width:34px;flex:none;">10</span><span style="font:400 23px 'Newsreader',serif;flex:1;">Movimiento y tokens de desarrollo</span><span style="font:500 13px 'Hanken Grotesk';color:#A99F90;">12</span></div>
    </div>

    <div style="position:absolute;bottom:48px;left:64px;right:64px;display:flex;justify-content:space-between;font:500 11px 'Hanken Grotesk';letter-spacing:0.12em;text-transform:uppercase;color:#B7AE9F;"><span>Elephant · Manual de marca</span><span>02</span></div>
  </div>

  <!-- ============ 03 · LA MARCA ============ -->
  <div class="bb-page" data-screen-label="La marca" style="position:relative;width:794px;height:1123px;flex:none;background:#F4EFE7;color:#221C16;box-shadow:0 24px 60px -28px rgba(20,16,40,0.35);padding:72px 64px 60px;">
    <div style="font:500 12px 'Hanken Grotesk';letter-spacing:0.22em;text-transform:uppercase;color:#A99F90;">01 · La marca</div>
    <h2 style="font:300 52px/1.04 'Newsreader',serif;letter-spacing:-0.02em;margin:14px 0 0;">No enseñamos inglés.<br><span style="font-style:italic;color:#2B2752;">Hacemos que lo recuerdes.</span></h2>
    <p style="font:400 21px/1.5 'Newsreader',serif;color:#4A4339;margin:26px 0 0;max-width:600px;">Elephant es una app de vocabulario que convierte cada palabra en una escena imposible de olvidar. No repites: recuerdas. El nombre lo dice todo — <span style="font-style:italic;">un elefante nunca olvida</span>.</p>

    <div style="display:grid;grid-template-columns:1fr 1fr;gap:18px;margin-top:40px;">
      <div style="background:#fff;border:1px solid #E8E1D3;border-radius:18px;padding:26px;">
        <div style="font:600 12px 'Hanken Grotesk';letter-spacing:0.16em;text-transform:uppercase;color:#5C7A61;">La promesa</div>
        <p style="font:400 22px/1.4 'Newsreader',serif;margin:14px 0 0;">«Aprende una palabra hoy. <span style="font-style:italic;color:#2B2752;">Recuérdala dentro de diez años.</span>»</p>
      </div>
      <div style="background:#fff;border:1px solid #E8E1D3;border-radius:18px;padding:26px;">
        <div style="font:600 12px 'Hanken Grotesk';letter-spacing:0.16em;text-transform:uppercase;color:#B0917E;">El mecanismo</div>
        <p style="font:400 19px/1.45 'Newsreader',serif;margin:14px 0 0;color:#4A4339;">Mnemotecnia — un <strong style="font-weight:600;color:#2B2752;">gancho fonético</strong> + una <strong style="font-weight:600;color:#2B2752;">escena absurda</strong> — reforzada con repetición espaciada.</p>
      </div>
    </div>

    <div style="display:grid;grid-template-columns:1fr 1fr;gap:18px;margin-top:18px;">
      <div style="background:#EFE8DB;border-radius:18px;padding:26px;">
        <div style="font:600 12px 'Hanken Grotesk';letter-spacing:0.16em;text-transform:uppercase;color:#5C7A61;margin-bottom:16px;">Elephant es…</div>
        <div style="display:flex;flex-direction:column;gap:11px;font:400 17px/1.35 'Newsreader',serif;color:#3E372E;">
          <div style="display:flex;gap:10px;"><span style="color:#5C7A61;">✓</span> Cálido, ingenioso, un poco travieso</div>
          <div style="display:flex;gap:10px;"><span style="color:#5C7A61;">✓</span> Editorial y silencioso — una idea por pantalla</div>
          <div style="display:flex;gap:10px;"><span style="color:#5C7A61;">✓</span> Memorable por la historia, no por la palabra</div>
          <div style="display:flex;gap:10px;"><span style="color:#5C7A61;">✓</span> Honesto sobre la ciencia de la memoria</div>
        </div>
      </div>
      <div style="background:#EFE8DB;border-radius:18px;padding:26px;">
        <div style="font:600 12px 'Hanken Grotesk';letter-spacing:0.16em;text-transform:uppercase;color:#B5524A;margin-bottom:16px;">Elephant no es…</div>
        <div style="display:flex;flex-direction:column;gap:11px;font:400 17px/1.35 'Newsreader',serif;color:#3E372E;">
          <div style="display:flex;gap:10px;"><span style="color:#B5524A;">✕</span> Gamificado — sin rachas ni rankings</div>
          <div style="display:flex;gap:10px;"><span style="color:#B5524A;">✕</span> Ruidoso, infantil o lleno de emojis</div>
          <div style="display:flex;gap:10px;"><span style="color:#B5524A;">✕</span> Un curso de gramática</div>
          <div style="display:flex;gap:10px;"><span style="color:#B5524A;">✕</span> Otra app de repetir hasta odiarlo</div>
        </div>
      </div>
    </div>

    <div style="position:absolute;bottom:48px;left:64px;right:64px;display:flex;justify-content:space-between;font:500 11px 'Hanken Grotesk';letter-spacing:0.12em;text-transform:uppercase;color:#B7AE9F;"><span>Elephant · Manual de marca</span><span>03</span></div>
  </div>

  <!-- ============ 04 · PERSONALIDAD Y TONO ============ -->
  <div class="bb-page" data-screen-label="Tono de voz" style="position:relative;width:794px;height:1123px;flex:none;background:#F4EFE7;color:#221C16;box-shadow:0 24px 60px -28px rgba(20,16,40,0.35);padding:72px 64px 60px;">
    <div style="font:500 12px 'Hanken Grotesk';letter-spacing:0.22em;text-transform:uppercase;color:#A99F90;">02 · Personalidad</div>
    <h2 style="font:300 52px/1.04 'Newsreader',serif;letter-spacing:-0.02em;margin:14px 0 0;">Cómo suena<br>Elephant</h2>

    <div style="display:flex;gap:10px;flex-wrap:wrap;margin-top:30px;">
      <span style="font:500 14px 'Hanken Grotesk';color:#2B2752;background:#fff;border:1px solid #E2DAC9;border-radius:999px;padding:9px 18px;">Cálido</span>
      <span style="font:500 14px 'Hanken Grotesk';color:#2B2752;background:#fff;border:1px solid #E2DAC9;border-radius:999px;padding:9px 18px;">Ingenioso</span>
      <span style="font:500 14px 'Hanken Grotesk';color:#2B2752;background:#fff;border:1px solid #E2DAC9;border-radius:999px;padding:9px 18px;">Directo</span>
      <span style="font:500 14px 'Hanken Grotesk';color:#2B2752;background:#fff;border:1px solid #E2DAC9;border-radius:999px;padding:9px 18px;">Sensorial</span>
      <span style="font:500 14px 'Hanken Grotesk';color:#2B2752;background:#fff;border:1px solid #E2DAC9;border-radius:999px;padding:9px 18px;">Sin rodeos</span>
      <span style="font:500 14px 'Hanken Grotesk';color:#2B2752;background:#fff;border:1px solid #E2DAC9;border-radius:999px;padding:9px 18px;">Un poco travieso</span>
    </div>

    <div style="margin-top:38px;display:flex;flex-direction:column;gap:14px;">
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:14px;">
        <div style="background:#fff;border:1px solid #E8E1D3;border-radius:16px;padding:22px;">
          <div style="font:600 11px 'Hanken Grotesk';letter-spacing:0.14em;text-transform:uppercase;color:#5C7A61;margin-bottom:12px;">Decimos</div>
          <p style="font:400 19px/1.4 'Newsreader',serif;margin:0;">«Abres el cajón y un DROmedario asoma la cabeza entre tus calcetines.»</p>
        </div>
        <div style="background:#fff;border:1px solid #E8E1D3;border-radius:16px;padding:22px;">
          <div style="font:600 11px 'Hanken Grotesk';letter-spacing:0.14em;text-transform:uppercase;color:#B5524A;margin-bottom:12px;">No decimos</div>
          <p style="font:400 19px/1.4 'Newsreader',serif;margin:0;color:#8B8174;">«Drawer significa cajón. Repítelo 10 veces para memorizarlo.»</p>
        </div>
      </div>
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:14px;">
        <div style="background:#fff;border:1px solid #E8E1D3;border-radius:16px;padding:22px;">
          <div style="font:600 11px 'Hanken Grotesk';letter-spacing:0.14em;text-transform:uppercase;color:#5C7A61;margin-bottom:12px;">Decimos</div>
          <p style="font:400 19px/1.4 'Newsreader',serif;margin:0;">«¿Seguirás acordándote dentro de un año?»</p>
        </div>
        <div style="background:#fff;border:1px solid #E8E1D3;border-radius:16px;padding:22px;">
          <div style="font:600 11px 'Hanken Grotesk';letter-spacing:0.14em;text-transform:uppercase;color:#B5524A;margin-bottom:12px;">No decimos</div>
          <p style="font:400 19px/1.4 'Newsreader',serif;margin:0;color:#8B8174;">«¡Aprende 5000 palabras rápido! 🚀🔥»</p>
        </div>
      </div>
    </div>

    <div style="margin-top:32px;background:#2B2752;border-radius:18px;padding:30px 32px;color:#F4EFE7;">
      <div style="font:600 11px 'Hanken Grotesk';letter-spacing:0.18em;text-transform:uppercase;color:rgba(232,184,129,0.9);margin-bottom:14px;">Tres reglas de oro</div>
      <div style="display:flex;flex-direction:column;gap:12px;font:400 19px/1.45 'Newsreader',serif;">
        <div><span style="color:#E8B881;font-style:italic;">Una idea por pantalla.</span> Nunca dos. El silencio es parte del mensaje.</div>
        <div><span style="color:#E8B881;font-style:italic;">La historia es la protagonista,</span> no la palabra inglesa.</div>
        <div><span style="color:#E8B881;font-style:italic;">Apela a los sentidos.</span> Lo concreto y absurdo se recuerda; lo abstracto se olvida.</div>
      </div>
    </div>

    <div style="position:absolute;bottom:48px;left:64px;right:64px;display:flex;justify-content:space-between;font:500 11px 'Hanken Grotesk';letter-spacing:0.12em;text-transform:uppercase;color:#B7AE9F;"><span>Elephant · Manual de marca</span><span>04</span></div>
  </div>

  <!-- ============ 05 · LOGOTIPO CONSTRUCCIÓN ============ -->
  <div class="bb-page" data-screen-label="Logotipo" style="position:relative;width:794px;height:1123px;flex:none;background:#F4EFE7;color:#221C16;box-shadow:0 24px 60px -28px rgba(20,16,40,0.35);padding:72px 64px 60px;">
    <div style="font:500 12px 'Hanken Grotesk';letter-spacing:0.22em;text-transform:uppercase;color:#A99F90;">03 · Logotipo</div>
    <h2 style="font:300 52px/1.04 'Newsreader',serif;letter-spacing:-0.02em;margin:14px 0 0;">La marca</h2>
    <p style="font:400 19px/1.5 'Newsreader',serif;color:#4A4339;margin:20px 0 0;max-width:560px;">El símbolo es un elefante de trazo lleno — orejas abiertas, trompa curva. Siempre acompañado del nombre en <strong style="font-weight:600;">Newsreader 600</strong>. El conjunto es discreto: vive en la esquina, nunca grita.</p>

    <div style="margin-top:34px;background:#fff;border:1px solid #E8E1D3;border-radius:20px;padding:48px;display:flex;align-items:center;justify-content:center;gap:18px;">
      <svg width="64" height="64" viewBox="0 0 64 64"><g fill="#221C16"><ellipse cx="12" cy="29" rx="8.5" ry="13"/><ellipse cx="52" cy="29" rx="8.5" ry="13"/><path d="M16 26 C16 15 25 11 32 11 C39 11 48 15 48 26 C48 35 44 41 40 44 C40.5 49 41 53 38 57.5 C36 60.5 32 60.5 31 57.5 C30.2 55 31.5 51.5 33 49.5 C27 47 18 40 16 26 Z"/></g></svg>
      <span style="font:600 46px 'Newsreader',serif;letter-spacing:-0.01em;">Elephant</span>
    </div>

    <div style="display:grid;grid-template-columns:1fr 1fr;gap:18px;margin-top:18px;">
      <div style="background:#fff;border:1px solid #E8E1D3;border-radius:18px;padding:24px;">
        <div style="font:600 12px 'Hanken Grotesk';letter-spacing:0.16em;text-transform:uppercase;color:#A99F90;margin-bottom:18px;">Área de respeto</div>
        <div style="position:relative;background:#F4EFE7;border-radius:12px;padding:30px;display:flex;align-items:center;justify-content:center;">
          <div style="position:absolute;inset:14px;border:1px dashed #CDBFA8;border-radius:8px;"></div>
          <svg width="48" height="48" viewBox="0 0 64 64"><g fill="#221C16"><ellipse cx="12" cy="29" rx="8.5" ry="13"/><ellipse cx="52" cy="29" rx="8.5" ry="13"/><path d="M16 26 C16 15 25 11 32 11 C39 11 48 15 48 26 C48 35 44 41 40 44 C40.5 49 41 53 38 57.5 C36 60.5 32 60.5 31 57.5 C30.2 55 31.5 51.5 33 49.5 C27 47 18 40 16 26 Z"/></g></svg>
        </div>
        <p style="font:400 15px/1.4 'Hanken Grotesk';color:#6E655A;margin:14px 0 0;">Reserva un margen igual a la altura de la oreja por cada lado. Nada invade ese espacio.</p>
      </div>
      <div style="background:#fff;border:1px solid #E8E1D3;border-radius:18px;padding:24px;">
        <div style="font:600 12px 'Hanken Grotesk';letter-spacing:0.16em;text-transform:uppercase;color:#A99F90;margin-bottom:18px;">Tamaño mínimo</div>
        <div style="background:#F4EFE7;border-radius:12px;padding:30px;display:flex;align-items:center;justify-content:center;gap:18px;">
          <div style="text-align:center;"><svg width="20" height="20" viewBox="0 0 64 64"><g fill="#221C16"><ellipse cx="12" cy="29" rx="8.5" ry="13"/><ellipse cx="52" cy="29" rx="8.5" ry="13"/><path d="M16 26 C16 15 25 11 32 11 C39 11 48 15 48 26 C48 35 44 41 40 44 C40.5 49 41 53 38 57.5 C36 60.5 32 60.5 31 57.5 C30.2 55 31.5 51.5 33 49.5 C27 47 18 40 16 26 Z"/></g></svg><div style="font:500 10px 'Hanken Grotesk';color:#A99F90;margin-top:6px;">20 px icono</div></div>
          <div style="text-align:center;"><span style="font:600 17px 'Newsreader',serif;">Elephant</span><div style="font:500 10px 'Hanken Grotesk';color:#A99F90;margin-top:6px;">17 px texto</div></div>
        </div>
        <p style="font:400 15px/1.4 'Hanken Grotesk';color:#6E655A;margin:14px 0 0;">Por debajo de 20 px el icono pierde el trazo. En digital, el lockup vive a 17 px (como en la app).</p>
      </div>
    </div>

    <div style="margin-top:18px;display:flex;gap:14px;">
      <div style="flex:1;background:#2B2752;border-radius:14px;padding:24px;display:flex;flex-direction:column;align-items:center;gap:12px;"><svg width="40" height="40" viewBox="0 0 64 64"><g fill="#F4EFE7"><ellipse cx="12" cy="29" rx="8.5" ry="13"/><ellipse cx="52" cy="29" rx="8.5" ry="13"/><path d="M16 26 C16 15 25 11 32 11 C39 11 48 15 48 26 C48 35 44 41 40 44 C40.5 49 41 53 38 57.5 C36 60.5 32 60.5 31 57.5 C30.2 55 31.5 51.5 33 49.5 C27 47 18 40 16 26 Z"/></g></svg><span style="font:500 11px 'Hanken Grotesk';color:rgba(244,239,231,0.6);">Crema sobre índigo</span></div>
      <div style="flex:1;background:#E8B881;border-radius:14px;padding:24px;display:flex;flex-direction:column;align-items:center;gap:12px;"><svg width="40" height="40" viewBox="0 0 64 64"><g fill="#241F40"><ellipse cx="12" cy="29" rx="8.5" ry="13"/><ellipse cx="52" cy="29" rx="8.5" ry="13"/><path d="M16 26 C16 15 25 11 32 11 C39 11 48 15 48 26 C48 35 44 41 40 44 C40.5 49 41 53 38 57.5 C36 60.5 32 60.5 31 57.5 C30.2 55 31.5 51.5 33 49.5 C27 47 18 40 16 26 Z"/></g></svg><span style="font:500 11px 'Hanken Grotesk';color:#5E4C2A;">Tinta sobre dorado</span></div>
